curl -X POST "https://comms.twilio.com/v1/Messages" \
--header "Content-Type: application/json" \
--data "{
    "to": [
        {
            "address": "+12065558844",
            "channel": "PHONE"
        }
    ],
    "content": {
        "text": "Hello, World!"
    },
    "from": {
        "address": "+14153901002",
        "channel": "SMS"
    }
}" \
-u $TWILIO_ACCOUNT_SID:$TWILIO_AUTH_TOKEN